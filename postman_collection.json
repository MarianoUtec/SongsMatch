    {
      "name": "Chat",
      "description": "Real-time chat between musical twins. Uses REST for history and WebSocket (STOMP) for real-time messaging. Connect to ws://localhost:8080/ws with SockJS, subscribe to /topic/conversations/{id} and /user/queue/messages.",
      "item": [
        {
          "name": "Get or Create Conversation with User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/conversations/with/2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "conversations",
                "with",
                "2"
              ]
            },
            "description": "Gets existing conversation with user ID 2 (your musical twin), or creates one if it doesn't exist. Returns all messages in the conversation."
          }
        },
        {
          "name": "Get My Conversations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/conversations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "conversations"
              ]
            },
            "description": "Returns all conversations the authenticated user is part of, with unread message count for each."
          }
        },
        {
          "name": "Send Message (REST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hey! I see we both love Frank Ocean 🎵\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/conversations/1/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "conversations",
                "1",
                "messages"
              ]
            },
            "description": "Sends a message via REST. Also broadcasts it via WebSocket to /topic/conversations/{id} and /user/queue/messages for the recipient. Returns 201 with the saved message."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"conversationId\": 1,\n  \"senderId\": 1,\n  \"senderName\": \"Alice\",\n  \"content\": \"Hey! I see we both love Frank Ocean 🎵\",\n  \"isRead\": false,\n  \"sentAt\": \"2026-05-21T15:00:00\"\n}"
            }
          ]
        },
        {
          "name": "Get Messages in Conversation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/conversations/1/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "conversations",
                "1",
                "messages"
              ]
            },
            "description": "Returns all messages in conversation 1 ordered chronologically. Also marks all messages from the other user as read."
          }
        }
      ]
    },
    {
      "name": "Twin History",
      "description": "History of musical twin evolution. Every time SVD is recomputed, a snapshot is saved. Shows how your musical twin has changed as you rate more songs.",
      "item": [
        {
          "name": "Get Full Twin History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me/twin-history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me",
                "twin-history"
              ]
            },
            "description": "Returns all historical snapshots of the authenticated user's latent profile since their first rating. Each entry shows coordX/Y/Z, closestUserId, closestUserName, compatibilityScore and ratingsCount at that point in time. Use this to visualize how the twin evolved."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"coordX\": -0.45, \"coordY\": 0.03, \"coordZ\": -0.34,\n    \"closestUserId\": 3,\n    \"closestUserName\": \"Carlos\",\n    \"compatibilityScore\": 78.0,\n    \"ratingsCount\": 3,\n    \"recordedAt\": \"2026-05-20T14:00:00\"\n  },\n  {\n    \"id\": 5,\n    \"coordX\": -0.41, \"coordY\": 0.08, \"coordZ\": -0.38,\n    \"closestUserId\": 2,\n    \"closestUserName\": \"Bob\",\n    \"compatibilityScore\": 94.0,\n    \"ratingsCount\": 8,\n    \"recordedAt\": \"2026-05-20T16:00:00\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Recent Twin History (last 10)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me/twin-history/recent",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me",
                "twin-history",
                "recent"
              ]
            },
            "description": "Returns the last 10 snapshots ordered by most recent first. Faster for the frontend when only showing recent changes."
          }
        }
      ]
    },
    {
      "name": "Social Feed",
      "description": "Shows recent ratings from users close to you in latent space (compatibility >= 50%). Lets you discover what your musical neighbors are rating.",
      "item": [
        {
          "name": "Get My Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/feed",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "feed"
              ]
            },
            "description": "Returns up to 20 recent ratings from the 5 users most compatible with you in the SVD latent space (compatibility >= 50%). Each feed item shows the user, their compatibility score, the song they rated and their score. Returns empty array if SVD hasn't been computed yet."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"userId\": 2,\n    \"userName\": \"Bob Torres\",\n    \"compatibilityScore\": 94.0,\n    \"song\": { \"id\": 3, \"title\": \"Retrograde\", \"artist\": \"James Blake\" },\n    \"score\": 5,\n    \"ratedAt\": \"2026-05-20T16:30:00\"\n  },\n  {\n    \"userId\": 2,\n    \"userName\": \"Bob Torres\",\n    \"compatibilityScore\": 94.0,\n    \"song\": { \"id\": 7, \"title\": \"Cómo Me Quieres\", \"artist\": \"Kevin Kaarl\" },\n    \"score\": 4,\n    \"ratedAt\": \"2026-05-20T16:25:00\"\n  }\n]"
            }
          ]
        }
      ]
    }
  ]
}